<ui version="4.0">
 <class>Movie</class>
 <widget class="QWidget" name="Movie">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>700</width>
    <height>600</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Movie</string>
  </property>
  <property name="styleSheet">
   <string notr="true">#Movie {
    background-color: #0F0F11;
}
QScrollArea {
    border: none;
    background-color: transparent;
}
QScrollArea > QWidget#qt_scrollarea_viewport {
    background-color: transparent;
}
#movieScrollContent {
    background-color: transparent;
}
QPushButton#movieBackButton {
    color: #FFFFFF;
    background-color: #181818;
    border: 1px solid #181818;
    border-radius: 8px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 600;
}
QPushButton#movieBackButton:hover {
    background-color: #232325;
    border-color: #2A2A2C;
}
QLabel#movieTitleLabel {
    color: #FFFFFF;
    font-size: 24px;
    font-weight: 700;
}
QLabel#movieMetaLabel {
    color: #6C6C6E;
    font-size: 13px;
}
QLabel#movieGenresLabel {
    color: #FFFFFF;
    font-size: 13px;
    background-color: #181818;
    border-radius: 8px;
    padding: 6px 10px;
}
QLabel#movieRatingLabel {
    color: #FFFFFF;
    font-size: 16px;
    font-weight: 700;
}
QLabel#movieReviewCountLabel {
    color: #6C6C6E;
    font-size: 13px;
}
QLabel#movieDescriptionLabel {
    color: #E6E6E6;
    font-size: 14px;
    line-height: 1.4;
}
QLabel#moviePosterLabel {
    background-color: #181818;
    border-radius: 8px;
}
QLabel#reviewsTitleLabel,
QLabel#addReviewTitleLabel {
    color: #FFFFFF;
    font-size: 18px;
    font-weight: 700;
}
QLabel#reviewsEmptyLabel {
    color: #6C6C6E;
    font-size: 13px;
}
QFrame#addReviewCard,
QFrame#reviewItem {
    background-color: #181818;
    border-radius: 12px;
    border: 1px solid #181818;
}
QLabel#ratingFieldLabel,
QLabel#commentFieldLabel {
    color: #FFFFFF;
    font-size: 13px;
    font-weight: 600;
}
QLabel#reviewItemUser {
    color: #FFFFFF;
    font-size: 13px;
    font-weight: 700;
}
QLabel#reviewItemRating {
    color: #FFFFFF;
    font-size: 13px;
    font-weight: 700;
}
QLabel#reviewItemComment {
    color: #E6E6E6;
    font-size: 13px;
}
QDoubleSpinBox#reviewRatingSpinBox {
    background-color: #0F0F11;
    color: #FFFFFF;
    border: 1px solid #2A2A2A;
    border-radius: 8px;
    padding: 6px 8px;
    min-height: 28px;
    min-width: 100px;
}
QPlainTextEdit#reviewCommentEdit {
    background-color: #0F0F11;
    color: #FFFFFF;
    border: 1px solid #2A2A2A;
    border-radius: 8px;
    padding: 8px 10px;
    font-size: 13px;
}
QPushButton#submitReviewButton {
    min-height: 36px;
    padding: 0 18px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 700;
    color: #FFFFFF;
    background-color: #AE1A19;
    border: 1px solid #AE1A19;
}
QPushButton#submitReviewButton:hover {
    background-color: #951615;
    border-color: #951615;
}
QPushButton#submitReviewButton:disabled {
    background-color: #3A1A1A;
    border-color: #3A1A1A;
    color: #6C6C6E;
}
QLabel#reviewStatusLabel {
    color: #6C6C6E;
    font-size: 12px;
}
QLabel#reviewStatusLabel[state=&quot;error&quot;] {
    color: #EF4444;
}
QLabel#reviewStatusLabel[state=&quot;success&quot;] {
    color: #22C55E;
}
QLabel#signInNoticeLabel {
    color: #6C6C6E;
    font-size: 13px;
}
QPushButton#movieFavoriteButton {
    color: #FFFFFF;
    background-color: #181818;
    border: 1px solid #181818;
    border-radius: 8px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 600;
    text-align: left;
}
QPushButton#movieFavoriteButton:hover {
    background-color: #232325;
    border-color: #2A2A2C;
}
QPushButton#movieFavoriteButton:checked {
    background-color: #232325;
    border-color: #FACC15;
    color: #FACC15;
}</string>
