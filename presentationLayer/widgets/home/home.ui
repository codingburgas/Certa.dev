}
#guestSubtitleLabel {
    color: #6C6C6E;
    font-size: 14px;
}
#guestSignInButton {
    background-color: #AE1A19;
    color: #FFFFFF;
    border: none;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 600;
    padding: 6px 16px;
    min-width: 140px;
    min-height: 32px;
}
#guestSignInButton:hover {
    background-color: #951615;
}
#recommendationsTitleLabel {
    color: #FFFFFF;
    font-size: 22px;
    font-weight: 700;
}
#recommendationsTitleAccent {
    background-color: #AE1A19;
    border-radius: 2px;
    min-width: 4px;
    max-width: 4px;
    min-height: 24px;
    max-height: 24px;
}
#noRecommendationsLabel {
    color: #6C6C6E;
    font-size: 14px;
}
#exploreMoreButton {
    background-color: transparent;
    color: #FFFFFF;
    border: 1px solid #AE1A19;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    padding: 4px 16px;
    min-height: 26px;
    max-height: 26px;
}
#exploreMoreButton:hover {
    background-color: rgba(174, 26, 25, 92);
}
QFrame#movieCard {
    background-color: #181818;
    border-radius: 8px;
    border: 1px solid #181818;
}
QFrame#movieCard:hover {
    background-color: #232325;
    border: 1px solid #2A2A2C;
}
QLabel#movieCardTitle {
    color: #FFFFFF;
    font-size: 13px;
    font-weight: 600;
}
QLabel#movieCardGenres {
    color: #6C6C6E;
    font-size: 11px;
}
QLabel#movieCardRating {
    color: #FFFFFF;
    font-size: 12px;
}
QLabel#movieCardReviews {
    color: #6C6C6E;
    font-size: 12px;
}</string>
