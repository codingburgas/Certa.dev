   <string notr="true">#Settings {
    background-color: #0F0F11;
}
QLabel {
    color: #FFFFFF;
    font-size: 14px;
}
QScrollArea {
    background-color: transparent;
}
QWidget#settingsScrollContent,
QWidget#termsScrollContent,
QWidget#privacyScrollContent {
    background-color: transparent;
}
QLabel#settingsTitleLabel,
QLabel#accountSectionLabel,
QLabel#profileSectionLabel,
QLabel#legalSectionLabel,
QLabel#dangerSectionLabel,
QLabel#termsTitleLabel,
QLabel#privacyTitleLabel {
    color: #FFFFFF;
    font-size: 20px;
    font-weight: 700;
}
QLabel#termsContentLabel,
QLabel#privacyContentLabel {
    color: #E6E6E6;
    font-size: 14px;
    line-height: 1.35;
}
QLabel#settingsNoticeLabel,
QLabel#usernameStatusLabel,
QLabel#passwordStatusLabel,
QLabel#interestsStatusLabel,
QLabel#deleteStatusLabel,
QLabel#accountHintLabel,
QLabel#profileHintLabel,
QLabel#dangerHintLabel {
    color: #6C6C6E;
    font-size: 12px;
}
QWidget#accountCard,
QWidget#profileCard,
QWidget#legalCard {
    background-color: #181818;
    border-radius: 12px;
}
QWidget#dangerCard {
    background-color: #2A1212;
    border-radius: 12px;
}
QLineEdit {
    background-color: #0F0F11;
    color: #FFFFFF;
    border: 1px solid #2A2A2A;
    border-radius: 8px;
    padding: 8px 10px;
}
QCheckBox {
    color: #FFFFFF;
    spacing: 8px;
    font-size: 13px;
    font-weight: 500;
    padding: 4px 6px;
    border: 1px solid transparent;
    border-radius: 8px;
}
QCheckBox:checked {
    border-color: #AE1A19;
}
QPushButton#saveUsernameButton,
QPushButton#savePasswordButton,
QPushButton#saveInterestsButton,
QPushButton#deleteAccountButton {
    min-height: 36px;
    padding: 0 18px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 700;
    color: #FFFFFF;
    background-color: #AE1A19;
    border: 1px solid #AE1A19;
}
QPushButton#saveUsernameButton:hover,
QPushButton#savePasswordButton:hover,
QPushButton#saveInterestsButton:hover,
QPushButton#deleteAccountButton:hover {
    background-color: #951615;
    border-color: #951615;
}
QPushButton#termsViewButton,
QPushButton#privacyViewButton,
QPushButton#termsBackButton,
QPushButton#privacyBackButton {
    min-height: 34px;
    padding: 0 16px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    color: #FFFFFF;
    background-color: #0F0F11;
    border: 1px solid #2A2A2A;
}
QPushButton#termsViewButton:hover,
QPushButton#privacyViewButton:hover,
QPushButton#termsBackButton:hover,
QPushButton#privacyBackButton:hover {
    border-color: #6C6C6E;
}
</string>
