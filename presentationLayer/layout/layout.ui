  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">
  *:focus {
     outline: none;
  }

  #centralwidget {
    background-color: #0F0F11;
  }

  #sidebarWidget {
    background-color: #0F0F11;
    border-right: 1px solid #181818;
  }

  #brandNameLabel {
    color: #FFFFFF;
    font-size: 28px;
    font-weight: 700;
    padding-left: 6px;
  }

  #brandSubLabel {
    color: #6C6C6E;
    font-size: 11px;
    letter-spacing: 2px;
    font-weight: 600;
    padding-left: 6px;
  }

  #topBarWidget {
    background-color: #0F0F11;
    border-bottom: 1px solid #181818;
  }

  #contentWidget {
    background-color: #0F0F11;
  }

  #stackedWidget {
    background-color: transparent;
  }

  #topBarSearchLineEdit {
    background-color: #181818;
    border: 1px solid #181818;
    border-radius: 14px;
    color: #FFFFFF;
    font-size: 13px;
    padding-left: 14px;
    padding-right: 14px;
    selection-background-color: #AE1A19;
  }

  #topBarSearchLineEdit:focus {
    border: 1px solid #AE1A19;
    background-color: #0F0F11;
  }

  #topBarUsernameLabel {
    color: #FFFFFF;
    font-size: 14px;
    font-weight: 600;
  }

  #topBarAvatarLabel {
    color: #FFFFFF;
    font-size: 14px;
    font-weight: 700;
    border-radius: 18px;
    background-color: #AE1A19;
  }

  #sidebarHomeButton,
  #sidebarMoviesButton,
  #sidebarRecommendationsButton,
  #sidebarFavoritesButton,
  #sidebarAuthButton,
  #sidebarSettingsButton {
    min-height: 48px;
    max-height: 48px;
    padding-left: 30px;
    padding-right: 16px;
    icon-size: 20px;
    font-size: 14px;
    font-weight: 400;
    text-align: left;
    border-radius: 14px;
    border: 1px solid transparent;
    background-color: transparent;
    color: #6C6C6E;
  }

  #sidebarHomeButton:checked,
  #sidebarMoviesButton:checked,
  #sidebarRecommendationsButton:checked,
  #sidebarFavoritesButton:checked,
  #sidebarAuthButton:checked,
  #sidebarSettingsButton:checked {
    background-color: rgba(174, 26, 25, 92);
    border-color: transparent;
    color: #FFFFFF;
  }

  #sidebarHomeButton:hover, #sidebarHomeButton:focus,
  #sidebarMoviesButton:hover, #sidebarMoviesButton:focus,
  #sidebarRecommendationsButton:hover, #sidebarRecommendationsButton:focus,
  #sidebarFavoritesButton:hover, #sidebarFavoritesButton:focus,
  #sidebarAuthButton:hover, #sidebarAuthButton:focus,
  #sidebarSettingsButton:hover, #sidebarSettingsButton:focus {
    background-color: rgba(149, 22, 21, 45);
    border-color: #181818;
    color: #FFFFFF;
  }

  #sidebarHomeButton:checked:hover, #sidebarHomeButton:checked:focus,
  #sidebarMoviesButton:checked:hover, #sidebarMoviesButton:checked:focus,
  #sidebarRecommendationsButton:checked:hover, #sidebarRecommendationsButton:checked:focus,
  #sidebarFavoritesButton:checked:hover, #sidebarFavoritesButton:checked:focus,
  #sidebarAuthButton:checked:hover, #sidebarAuthButton:checked:focus,
  #sidebarSettingsButton:checked:hover, #sidebarSettingsButton:checked:focus {
    background-color: rgba(174, 26, 25, 120);
    border-color: transparent;
    color: #FFFFFF;
  }

  #sidebarDivider {
    background-color: #2A2A2C;
    border: none;
  }
  </string>
