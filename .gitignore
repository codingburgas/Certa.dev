# -----------------------------
# Certa.dev: Gitignore
# Generated/IDE/build files for Qt + CMake projects
# -----------------------------

# Build directories
/build/
/Desktop_Qt_*/
/cmake-*/

# CMake files
/CMakeFiles/
/CMakeCache.txt
/cmake_install.cmake
/Makefile
/Makefile.cmake
/rules.ninja
/build.ninja
/Testing/
/CTestTestfile.cmake

# Compiled object files, libraries, executables
*.o
*.obj
*.lo
*.la
*.al
*.lai
*.a
*.lib
*.so
*.dylib
*.dll
*.exe

# Qt autogenerated files
*moc_*.cpp
moc_*.cpp
moc_*.o
*.moc
*.qrc
*.rcc
*.qrc.cpp

# Qt Creator / Qt Creator session
*.pro.user
*.pro.user.*

# Qt build artifacts
*.qmlc
*.qmltypes

# IDEs and editors
.idea/
.vscode/
.github/
.opencode/
*.sublime-workspace
*.sublime-project

# CLion / JetBrains
/cmake-build-*/
clion-*.txt

# Visual Studio
*.vcxproj*
*.suo
*.user
*.userosscache
*.sdf
*.cache

# Qt resource and meta files
*.qmake.stash

# Logs, temp files
*.log
*.tmp
*.temp

# macOS / Windows
.DS_Store
Thumbs.db

# User-specific files
*.local

# Assets build output
/assets/build/

# Ignore Qt Creator project files that are generated
*.qmlproject.user
